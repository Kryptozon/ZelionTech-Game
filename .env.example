# ===== Telegram =====
BOT_TOKEN=123456:PASTE_TOKEN_FROM_BOTFATHER
BOT_USERNAME=ZelionTechGameBot
# Comma-separated Telegram numeric user IDs that may use admin commands.
ADMIN_IDS=8883747941
# Super-admin dashboard password (hashed server-side; never sent to the frontend).
# Set the REAL value in your host's environment only — never commit it.
ADMIN_DASHBOARD_PASSWORD=change-me
# TEMP diagnostics: set true to expose GET /api/admin/debug (no secrets). Turn off after.
ADMIN_DEBUG=false

# ===== Launch mode =====
APP_ENV=production          # production | development
DEBUG=false                 # true => verbose logging
LOG_LEVEL=                  # override: DEBUG|INFO|WARNING|ERROR (blank => auto from DEBUG)

# ===== Database / cache =====
DATABASE_URL=postgresql://zelion:zelion@db:5432/zelion
REDIS_URL=redis://redis:6379/0
# Used by docker-compose for the Postgres container (keep in sync with DATABASE_URL):
POSTGRES_USER=zelion
POSTGRES_PASSWORD=zelion
POSTGRES_DB=zelion

# ===== Webhook (set USE_WEBHOOK=true for production behind nginx+HTTPS) =====
USE_WEBHOOK=false
WEBHOOK_BASE=https://your-domain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=change-this-long-random-string
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ===== Phase 2: Telegram auto-verify (bot must be admin/member of these) =====
TG_OFFICIAL_CHAT=@zeliontechofficial
TG_GLOBAL_CHAT=@zelionglobal

# ===== Phase 2: Group activity rewards =====
# Numeric chat id of your community group (0 = accept any group the bot is in).
# Get it by adding the bot, posting a message, and reading logs, or via @userinfobot in the group.
GROUP_CHAT_ID=-1003423593105
GROUP_MSG_XP=3
GROUP_MSG_DAILY_CAP=15
GROUP_MSG_MIN_LEN=20         # anti-spam: ignore messages under 20 chars
GROUP_FLOOD_SEC=90          # anti-spam: max 1 rewarded message / 90s
GROUP_REPLY_XP=4
GROUP_DISCUSSION_XP=15
GROUP_REACT_XP=2
GROUP_REACT_DAILY_CAP=10
DISCUSSION_HOUR=9           # UTC hour to auto-post the daily discussion topic
# NOTE: proof moderation is now in the Mini App Admin Dashboard — no PROOF_REVIEW_CHAT_ID needed.

# ===== Phase 2/3: Surge hours (UTC) + weekly winner bonuses =====
# Comma-separated UTC hours to auto-trigger a surge, e.g. "18,21". Empty = manual only via /surge.
SURGE_HOURS=
SURGE_MULT=2
SURGE_DURATION_MIN=60
WEEKLY_BONUS=500,300,200

# ===== Mini App (Telegram Web App) =====
MINIAPP_URL=https://zeliontech-game.onrender.com/app
FRONTEND_DIST=frontend/dist
WEB_ALWAYS=true             # serve API even in polling mode (Mini App needs it)
INITDATA_TTL=86400          # max age of WebApp initData in seconds

# ===== ZelionTech knowledge base + AI quiz =====
WEBSITE_URL=https://zeliontech.com
KB_MAX_PAGES=25
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=                 # optional; empty => grounded fallback generator (no facts invented)
AI_MODEL=gpt-4o-mini

# ===== Official ZelionTech links (used to seed social missions) =====
LINK_FACEBOOK=https://www.facebook.com/share/17ikJfJe84/?mibextid=wwXIfr
LINK_TELEGRAM_OFFICIAL=https://t.me/zeliontechofficial
LINK_TELEGRAM_GLOBAL=https://t.me/zelionglobal
LINK_X=https://x.com/zelion_tech
LINK_LINKEDIN=https://www.linkedin.com/company/zeliontech/
LINK_INSTAGRAM=https://www.instagram.com/zeliontech_zev
LINK_WHATSAPP=https://whatsapp.com/channel/0029VbCfgk34tRrtdCdS392k
LINK_TIKTOK=https://www.tiktok.com/@zeliontech_zev
LINK_DISCORD=https://discord.gg/7n8NCExs5
LINK_YOUTUBE=https://www.youtube.com/@ZelionTech
